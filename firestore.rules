rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isFamilyMember(familyId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
    }

    // Users
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    // Families
    match /families/{familyId} {
      // Any authenticated user can get a specific family doc (needed to join via invite code)
      allow get: if isAuth();
      // List is restricted to members only
      allow list: if isAuth() && request.auth.uid in resource.data.memberIds;
      allow create: if isAuth();
      // Members can update anything; non-members can only add themselves to memberIds
      allow update: if isAuth() && (
        request.auth.uid in resource.data.memberIds
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.auth.uid in request.resource.data.memberIds
        )
      );

      // Calendar entries
      match /calendar/{entryId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Grocery items
      match /grocery/{itemId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Diversity tracking
      match /diversity/{weekId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Activity feed
      match /activity/{activityId} {
        allow read, write: if isFamilyMember(familyId);
      }
    }

    // Invites
    match /invites/{code} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Recipes
    match /recipes/{id} {
      allow read: if ('isPublic' in resource.data && resource.data.isPublic == true)
        || (isAuth() && 'createdBy' in resource.data && request.auth.uid == resource.data.createdBy)
        || (isAuth() && 'savedBy' in resource.data && request.auth.uid in resource.data.savedBy)
        || (isAuth() && 'familyId' in resource.data && resource.data.familyId is string && resource.data.familyId != '' && isFamilyMember(resource.data.familyId));
      allow create: if isAuth();
      allow update: if isAuth() && (
        ('createdBy' in resource.data && request.auth.uid == resource.data.createdBy)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['savedBy'])
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['communityScore', 'ratingCount'])
      );
      allow delete: if isAuth() && 'createdBy' in resource.data && request.auth.uid == resource.data.createdBy;

      // Ratings
      match /ratings/{userId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == userId;
      }
    }

    // Reference data (public read only)
    match /produce/{id} { allow read: if true; }
    match /cuisines/{id} { allow read: if true; }
  }
}
